{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-control-regex": "allow",
    "no-unused-vars": "allow"
  },
  "ignorePatterns": [
    "build/**",
    "build-cws/**",
    "dist/**",
    "node_modules/**",
    "release-artifacts/**",
    "test-artifacts/**",
    "src/assets/mediapipeVision/**",
    "src/assets/vendor/**",
    "src/assets/whisper/**"
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "webextensions": true
  }
}
