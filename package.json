{
  "name": "sayless",
  "version": "4.6.0",
  "description": "Free to use, offline, local-first screen recorder with on-device transcription and word-based editing. No signup required.",
  "scripts": {
    "build": "cross-env NODE_ENV=production node utils/build.cts",
    "build:dev": "cross-env NODE_ENV=development node utils/build.cts",
    "build:prod": "cross-env NODE_ENV=production node utils/build.cts",
    "build:release": "cross-env NODE_ENV=production SAYLESS_SKIP_ENV=true node utils/build.cts",
    "build:local": "cross-env NODE_ENV=production SAYLESS_USE_LOCAL_ENV=1 node utils/build.cts",
    "start": "cross-env NODE_ENV=development node utils/server.cts",
    "dev": "npm run hot-reload",
    "watch": "cross-env NODE_ENV=development webpack --config webpack.config.cts --watch",
    "hot-reload": "cross-env NODE_ENV=development webpack serve --config webpack.config.cts --hot",
    "prettier": "prettier --write '**/*.{js,jsx,ts,tsx,json,css,scss,md}'",
    "typecheck": "node scripts/typecheck.mjs",
    "typecheck:legacy": "tsc --noEmit --pretty false",
    "postinstall": "patch-package && node scripts/patch-radix.cts",
    "package": "npm run package:release",
    "package:release": "node scripts/package-release.mjs",
    "package:ci-extension": "node scripts/package-ci-extension.mjs",
    "build:cws": "node scripts/package-cws.mjs",
    "preflight:cws": "npm run qa:release:status -- --require-ready",
    "verify:cws-package": "node scripts/verify-cws-package.mjs",
    "release:cws": "npm run build:cws && npm run verify:cws-package && npm run preflight:cws && dotenv -e .env.local -- chrome-webstore-upload upload --source build-cws.zip",
    "release:cws:force": "npm run release:cws",
    "release:cws:publish": "npm run preflight:cws && npm run verify:cws-package && dotenv -e .env.local -- chrome-webstore-upload publish",
    "release:cws:publish:10": "npm run preflight:cws && npm run verify:cws-package && dotenv -e .env.local -- chrome-webstore-upload publish --deploy-percentage 10",
    "release:cws:publish:50": "npm run preflight:cws && npm run verify:cws-package && dotenv -e .env.local -- chrome-webstore-upload publish --deploy-percentage 50",
    "clean": "rm -rf build && mkdir build",
    "lint": "npm run typecheck",
    "build:content-css": "sass src/pages/Content/styles/app.scss src/pages/Content/styles/app.css --no-source-map",
    "verify:zip": "node scripts/verify-no-secrets.mjs",
    "verify:whisper-assets": "node scripts/verify-local-whisper-assets.mjs",
    "verify:whisper-assets:build": "node scripts/verify-local-whisper-assets.mjs --build",
    "verify:release": "node scripts/release-audit.mjs",
    "verify:release-package": "node scripts/verify-release-package.mjs",
    "qa:release:status": "node scripts/release-status.mjs",
    "qa:release:auto": "node scripts/release-qa-automated.mjs",
    "qa:release:manual": "node scripts/verify-manual-qa-evidence.mjs",
    "qa:release:manual:progress": "node scripts/verify-manual-qa-evidence.mjs --progress",
    "qa:release:manual:media": "node scripts/manual-qa-media-probe.mjs",
    "qa:release:manual:sidecars": "node scripts/manual-qa-sidecar-probe.mjs",
    "qa:release:manual:measurements": "node scripts/apply-manual-qa-measurements.mjs",
    "qa:release:manual:profile": "node scripts/manual-qa-profile.mjs",
    "qa:release:manual:template": "node scripts/verify-manual-qa-evidence.mjs --write-template",
    "qa:release:manual:template:force": "node scripts/verify-manual-qa-evidence.mjs --write-template --force",
    "release": "node scripts/release.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:e2e:fast": "SAYLESS_E2E_HEADLESS=1 playwright test --config tests/playwright.config.ts",
    "test:e2e:offline-whisper-assets": "SAYLESS_E2E_HEADLESS=1 node tests/e2e/run-offline-whisper-assets.cjs",
    "test:e2e:offline-transcription-smoke": "SAYLESS_E2E_HEADLESS=1 node tests/e2e/run-offline-transcription-smoke.cjs",
    "test:e2e:offline-transcription-speech": "SAYLESS_E2E_HEADLESS=1 node tests/e2e/run-offline-transcription-speech.cjs",
    "test:e2e:editor-layout": "SAYLESS_E2E_HEADLESS=1 node tests/e2e/run-editor-layout.cjs",
    "test:e2e:webcodecs-mic-quality": "SAYLESS_E2E_HEADLESS=1 node tests/e2e/run-webcodecs-mic-quality.cjs",
    "test:e2e:editor-editing-proof": "SAYLESS_E2E_HEADLESS=1 node tests/e2e/run-editor-editing-proof.cjs",
    "test:e2e:built-extension-surface": "node tests/e2e/run-built-extension-surface.cjs",
    "test:e2e:local-recordings": "SAYLESS_E2E_HEADLESS=1 node tests/e2e/run-local-recordings.cjs"
  },
  "dependencies": {
    "@babel/plugin-transform-react-jsx": "^7.27.1",
    "@huggingface/transformers": "^3.8.1",
    "@mediapipe/tasks-vision": "0.10.32",
    "@radix-ui/react-alert-dialog": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.2",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-popover": "^1.0.5",
    "@radix-ui/react-select": "^1.2.1",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-switch": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.3",
    "@radix-ui/react-toast": "^1.2.13",
    "@radix-ui/react-toggle": "^1.1.8",
    "@radix-ui/react-toggle-group": "^1.1.9",
    "@radix-ui/react-toolbar": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.6",
    "@uiw/color-convert": "^1.2.2",
    "@uiw/react-color-wheel": "^1.2.2",
    "concurrently": "^8.2.0",
    "dotenv": "^17.0.1",
    "fabric": "^6.9.1",
    "fix-webm-duration": "^1.0.5",
    "gif.js": "^0.2.0",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "mediabunny": "^1.46.0",
    "patch-package": "^8.0.0",
    "raw-loader": "^4.0.2",
    "react": "^18.2.0",
    "react-advanced-cropper": "^0.19.4",
    "react-dom": "^18.2.0",
    "react-rnd": "^10.4.1",
    "react-shadow": "^20.0.0",
    "react-svg": "^16.1.18",
    "tar": "7.5.9",
    "wavesurfer.js": "^7.4.2",
    "webm-duration-fix": "^1.0.4"
  },
  "devDependencies": {
    "@babel/core": "^7.20.2",
    "@babel/plugin-transform-runtime": "^7.27.1",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.27.1",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.2.2",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "babel-loader": "^9.1.3",
    "chrome-webstore-upload-cli": "^3.5.0",
    "copy-webpack-plugin": "^7.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.7.2",
    "dotenv-cli": "^11.0.0",
    "fs-extra": "^10.1.0",
    "html-loader": "^3.1.0",
    "html-webpack-plugin": "^5.5.0",
    "prettier": "^2.7.1",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "source-map-loader": "^3.0.1",
    "style-loader": "^3.3.1",
    "stylelint": "^17.8.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "terser-webpack-plugin": "^5.3.6",
    "ts-loader": "^9.4.1",
    "typescript": "^5.9.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.11.1"
  },
  "overrides": {
    "tar": "7.5.9",
    "minimatch": "10.2.2"
  }
}
